# ─────────────────────────────────────────────────────────────────
# ISOMAC — .gitignore (Azure deployment)
# ─────────────────────────────────────────────────────────────────

# ── Secrets & Environment Variables (NEVER commit) ───────────────
.env
.env.*
!.env.example
*.env
backend/.env
frontend-react/.env
frontend-react/.env.production

# ── Dependencies (reinstalled via npm ci) ────────────────────────
node_modules/
*/node_modules/

# ── Build outputs (built inside Docker / CI) ─────────────────────
dist/
build/
frontend-react/dist/

# ── Logs ──────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-error.log*

# ── OS files ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Backups ───────────────────────────────────────────────────────
backend/backups/
*.bak

# ── Test coverage ─────────────────────────────────────────────────
coverage/

# ── Kiro ──────────────────────────────────────────────────────────
.kiro/

# ── Hugging Face specific (not needed for Azure) ──────────────────
README_HF.md

# ── Vercel config (using Azure, not Vercel) ───────────────────────
frontend-react/vercel.json

# ── Inventory submodule (separate repo) ───────────────────────────
inventory/

# ── Temp files ────────────────────────────────────────────────────
*.tmp

# ─────────────────────────────────────────────────────────────────────────────
# ISOMAC — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB connection string (Atlas SRV or local)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING

# Server
HOST=0.0.0.0
PORT=5000

# CORS — set to your frontend domain in production
CORS_ORIGIN=https://yourdomain.com

# Alert thresholds (days before expiry to trigger alert)
ALERT_WARRANTY_DAYS=30
ALERT_LICENSE_DAYS=30
ALERT_MAINTENANCE_DAYS=3

# Password policy
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=false

# Organization identifier (embedded in JWT payload)
ORGANIZATION_ID=your-org-id

# Super Admin (hardcoded username, configurable password)
# Username is always: sachinforoffice23
# Set a strong password here — this account has full system access
SUPER_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Google OAuth2 — get credentials from Google Cloud Console
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Leave blank to disable Google login
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://yourdomain.com/auth/google/callback
GOOGLE_DEFAULT_ROLE=viewer

# ─── SAML SSO ────────────────────────────────────────────────────────────────
# Set SAML_ENABLED=true to activate SAML SSO (Azure AD, Okta, Google Workspace)
SAML_ENABLED=false
SAML_ENTRY_POINT=https://login.microsoftonline.com/<tenant-id>/saml2
SAML_ISSUER=https://isomac-production-5b81.up.railway.app
SAML_CALLBACK_URL=https://isomac-production-5b81.up.railway.app/auth/saml/callback
# IdP certificate — paste the X.509 cert from your IdP (newlines as \n)
SAML_CERT=REPLACE_WITH_IDP_CERTIFICATE
# Default role for new SAML users: viewer | editor | employee
SAML_DEFAULT_ROLE=viewer
# Set to true to allow public email domains (gmail.com etc.) via SAML
SAML_ALLOW_PUBLIC_DOMAINS=false


LDAP_ENABLED=false
LDAP_URL=ldap://dc.company.com:389
LDAP_BASE_DN=dc=company,dc=com
LDAP_BIND_DN=cn=svc-isomac,ou=ServiceAccounts,dc=company,dc=com
LDAP_BIND_PASS=service-account-password
LDAP_USER_FILTER=(sAMAccountName={{username}})
LDAP_DEFAULT_ROLE=viewer
LDAP_TLS_REJECT_UNAUTHORIZED=true

# Email notifications for alerts (nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_EMAIL_TO=admin@yourcompany.com,it@yourcompany.com
EMAIL_FROM=isomac-alerts@yourcompany.com

# Backup
BACKUP_RETAIN_DAYS=7

# Environment — MUST be 'production' in production deployments
NODE_ENV=production

# ─── Sentry — Error Tracking & Performance Monitoring ────────────────────────
# Get DSN from: Sentry → Project Settings → Client Keys (DSN)
# Leave blank to disable Sentry entirely (safe for local dev).
SENTRY_DSN=

# Environment tag shown in Sentry UI — use: development | staging | production
# Defaults to NODE_ENV if not set.
SENTRY_ENVIRONMENT=production

# Release identifier — shown in Sentry for source map linking and regression tracking.
# Recommended: use your git SHA or semver tag.
# Example: SENTRY_RELEASE=1.4.2  or  SENTRY_RELEASE=abc1234
SENTRY_RELEASE=

# Performance monitoring sample rates (0.0 = off, 1.0 = 100% of requests)
# Production: keep low to avoid overhead. Staging: 1.0 for full visibility.
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ─── Sentry Alert Rules (configure in Sentry UI, not here) ───────────────────
# After setting SENTRY_DSN, create these alert rules in Sentry → Alerts:
#
# 1. High Error Rate
#    Trigger: Number of errors > 10 in 5 minutes
#    Filter:  environment = production
#    Action:  Email + Slack
#
# 2. Auth Failures (brute force / credential stuffing)
#    Trigger: issue.title = "AUTH_FAILURE" AND count > 20 in 5 minutes
#    Filter:  environment = production
#    Action:  Email + PagerDuty (high severity)
#
# 3. Token Reuse (possible token theft)
#    Trigger: issue.title = "AUTH_FAILURE" AND tag[auth_action] = "TOKEN_REUSE_DETECTED"
#    Filter:  environment = production
#    Action:  PagerDuty (critical)
#
# 4. Tenant Rejected (orphan users or deactivated tenants)
#    Trigger: issue.title = "AUTH_FAILURE" AND tag[auth_action] = "TENANT_REJECTED"
#    Filter:  environment = production
#    Action:  Email
#
# 5. P95 Latency
#    Trigger: p95(transaction.duration) > 2000ms
#    Filter:  environment = production
#    Action:  Slack
